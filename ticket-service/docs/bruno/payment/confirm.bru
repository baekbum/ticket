meta {
  name: Confirm Payment
  type: http
  seq: 1
}

post {
  url: {{ticketBaseUrl}}/payments/confirm
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "paymentNo": "{{paymentNo}}",
    "paidAt": "2026-07-14T22:07:43"
  }
}
