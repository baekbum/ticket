meta {
  name: Insert Area Svg
  type: http
  seq: 1
}

post {
  url: {{ticketBaseUrl}}/manage/area/insert/svg
  body: multipartForm
  auth: bearer
}

params:query {
  force: false
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  eventId: {{eventId}}
  svgFile: @file(samples/area-layout.svg)
}
