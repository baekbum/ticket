meta {
  name: Update Area
  type: http
  seq: 3
}

put {
  url: {{ticketBaseUrl}}/manage/area/update/id/{{areaId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "areaName": "VIP A",
    "grade": "VIP",
    "price": 150000,
    "status": "ACTIVE"
  }
}
