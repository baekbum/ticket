meta {
  name: Update User By Id
  type: http
  seq: 4
}

put {
  url: {{userBaseUrl}}/manage/update/id/{{userId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "phoneNumber": "010-7777-0001",
    "email": "managed-user@example.com",
    "birthDate": "1995-01-01",
    "address": "서울특별시 송파구 올림픽로 300",
    "isBlacklisted": false,
    "role": "USER",
    "grade": "NORMAL"
  }
}
