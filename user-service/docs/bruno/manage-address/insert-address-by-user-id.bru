meta {
  name: Insert Address By User Id
  type: http
  seq: 3
}

post {
  url: {{userBaseUrl}}/manage/address/insert/user/{{userId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "alias": "관리자 등록 주소",
    "recipientName": "이지은",
    "recipientPhone": "010-1111-2222",
    "zipCode": "05540",
    "address": "서울특별시 송파구 올림픽로 300",
    "detailAddress": "101동 1203호",
    "defaultAddress": false
  }
}
