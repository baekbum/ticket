meta {
  name: Select Addresses By User Id
  type: http
  seq: 3
}

post {
  url: {{userBaseUrl}}/manage/address/select/user/{{userId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "page": 0,
    "size": 10,
    "sort": [
      "addressId-desc"
    ]
  }
}
